# Base URL of the RecruitSphereAI.Api backend.
# In dev, vite.config.ts already proxies /api -> http://localhost:5150,
# so you can usually leave this as /api. Point it at the full origin
# (e.g. https://localhost:7126/api) if you disable the proxy or deploy
# the frontend separately from the backend.
VITE_API_BASE_URL=/api
